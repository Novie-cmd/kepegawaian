rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Document ID: employeeId
    // Fields:
    //   - id: string (required)
    //   - nip: string (required)
    //   - nama: string (required)
    //   - uid: string (required) - owner of the document
    //   - [other fields]: string (optional)
    //
    // Collection: agency_configs
    // Document ID: configId
    // Fields:
    //   - namaPemerintah: string (required)
    //   - namaSkpd: string (required)
    //   - uid: string (required) - owner of the document
    //   - [other fields]: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "noviharyanto062@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidEmployee(data) {
      return hasRequiredFields(['id', 'nip', 'nama', 'uid']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.nip is string && data.nip.size() > 0 && data.nip.size() < 50 &&
             data.nama is string && data.nama.size() > 0 && data.nama.size() < 200 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidAgencyConfig(data) {
      return hasRequiredFields(['namaPemerintah', 'namaSkpd', 'uid']) &&
             data.namaPemerintah is string && data.namaPemerintah.size() > 0 && data.namaPemerintah.size() < 200 &&
             data.namaSkpd is string && data.namaSkpd.size() > 0 && data.namaSkpd.size() < 200 &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /employees/{employeeId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidEmployee(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidEmployee(request.resource.data) && isDocOwner() && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /agency_configs/{configId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidAgencyConfig(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidAgencyConfig(request.resource.data) && isDocOwner() && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
